{
  "mcpServers": {
    "maestro-status": {
      "type": "stdio",
      "command": "/path/to/maestro-mcp-server",
      "args": [],
      "env": {
        "MAESTRO_STATUS_URL": "http://127.0.0.1:9900/status",
        "MAESTRO_INSTANCE_ID": "<instance-uuid>",
        "MAESTRO_SESSION_ID": "1"
      }
    }
  }
}
